# Qwen Cloud API key (get from https://www.qwencloud.com/)
DASHSCOPE_API_KEY=sk-your-key-here

# Optional: Supabase (for persistence across restarts)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# Optional: IBKR connection (falls back to mock broker if unavailable)
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1
